# ── AI Provider API Keys ───────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GEMINI_API_KEY=AIza...

# ── Database (Supabase) ────────────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → Database → Connection string → URI
# Use the "Transaction" pooler URL (port 6543) for serverless/edge environments.
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-eu-west-1.pooler.supabase.com:6543/postgres

# ── Auth (nuxt-auth-utils) ────────────────────────────────────────────────────
# Must be at least 32 random characters — used to encrypt the session cookie.
# Generate with: openssl rand -base64 32
NUXT_SESSION_PASSWORD=change-me-to-a-random-32-char-string

# ── Google OAuth ───────────────────────────────────────────────────────────────
# Create OAuth credentials at: https://console.cloud.google.com/apis/credentials
# Authorised redirect URI: http://localhost:3000/auth/google (dev)
#                          https://yourdomain.com/auth/google (prod)
NUXT_OAUTH_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
NUXT_OAUTH_GOOGLE_CLIENT_SECRET=GOCSPX-...

# -- Microsoft OAuth (Azure AD) ───────────────────────────────────────────────
# Create an app registration in Azure AD: https://portal.azure.com/#blade/Microsoft_Azure_AD/ApplicationsListBlade
# Authorised redirect URI: http://localhost:3000/auth/microsoft (dev)
#                          https://yourdomain.com/auth/microsoft (prod)
NUXT_OAUTH_MICROSOFT_CLIENT_ID=...
NUXT_OAUTH_MICROSOFT_CLIENT_SECRET=...
NUXT_OAUTH_MICROSOFT_TENANT=common

# ── Supabase public URL (optional — only needed if using Supabase client-side) ──
SUPABASE_URL=https://[project-ref].supabase.co
